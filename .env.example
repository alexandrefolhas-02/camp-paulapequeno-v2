# ============================================
# Paula Pequeno Elite Camp — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local nunca deve ser commitado (já está no .gitignore).

# --- Tracking ---
# Meta Pixel ID (encontrado em Eventos Manager > Configurações)
VITE_PIXEL_ID=

# Google Analytics 4 — Measurement ID (formato G-XXXXXXXXXX)
VITE_GA4_ID=

# --- Contato ---
# Número do WhatsApp Business no formato internacional, sem + ou espaços
# Exemplo: 5521999999999 (Brasil = 55, DDD 21, número)
VITE_WHATSAPP_NUMBER=5521999999999

# Mensagem padrão pré-preenchida ao clicar no botão de WhatsApp
VITE_WHATSAPP_MESSAGE=Olá! Quero saber mais sobre o Paula Pequeno Elite Camp.

# --- Links de Pagamento PagBank ---
# Link gerado no PagBank para o lote ATLETA FUNDADOR (R$ 1.997)
VITE_PAGBANK_LINK_FUNDADOR=https://pag.ae/

# Link gerado no PagBank para o lote REGULAR (R$ 2.434)
VITE_PAGBANK_LINK_REGULAR=https://pag.ae/

# Link gerado no PagBank para ALUNOS DA ESCOLA (R$ 1.947,20)
# Usado apenas no atendimento via WhatsApp, não exposto na LP
VITE_PAGBANK_LINK_ESCOLA=https://pag.ae/

# --- Controle de Vagas ---
# Vagas restantes do lote Atleta Fundador (de 30 totais)
# Atualizar manualmente no painel da Vercel conforme João Vitor confirma pagamentos
VITE_VAGAS_FUNDADOR=23

# Vagas totais restantes do Camp (de 60 totais)
VITE_VAGAS_TOTAL=53

# --- Data limite do Lote Fundador ---
# Formato: YYYY-MM-DD — usado no countdown da barra sticky
VITE_DATA_LIMITE_FUNDADOR=2026-06-15

# --- Ambiente ---
# Define se está em produção (afeta logs de tracking)
VITE_ENV=development
